rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users collection - anyone authenticated can read, only owner can write
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Group chat messages - any authenticated user can read/write
    match /mensajes/{messageId} {
      allow read, write: if request.auth != null;
    }
    
    // Private chats - only participants can read/write
    match /privateChats/{chatId} {
      allow read, write: if request.auth != null && 
        request.auth.uid in resource.data.participants;
      // Allow create if user is in the participants list
      allow create: if request.auth != null;
      
      // Messages subcollection
      match /messages/{messageId} {
        allow read: if request.auth != null && 
          get(/databases/$(database)/documents/privateChats/$(chatId)).data.participants.hasAny([request.auth.uid]);
        allow create: if request.auth != null;
      }
    }
  }
}
